# 4K Cinema — AWS Burst/DR 스택 환경변수 (cp .env.example .env)
# ⚠️ 이 파일은 .gitignore 됨. 실제 값은 카카오(K3s)의 시크릿과 "동일하게" 맞춰야
#    failover 시 세션·키 검증이 깨지지 않는다(= env 패리티).

# ── 백엔드(FastAPI) ───────────────────────────────────────────────
# TMDB 메타데이터 수집용 API 키
TMDB_API_KEY=

# Supabase REST 엔드포인트.
#  - 평상시/Burst: data.peakly.art = Route53 primary → 카카오 Supabase (단일 writer 유지)
#  - DR(카카오 다운): data.peakly.art failover → 이 EC2 옆 PostgREST(레플리카, Step 5)
#    또는 로컬 PostgREST를 직접 가리키도록 교체 (예: http://postgrest:3000)
DATA_SUPABASE_URL=https://data.peakly.art
# Supabase service_role JWT (쓰기 권한). 카카오와 동일 값.
DATA_SUPABASE_KEY=

# ── 매니저 로그인 (FE) — 카카오와 반드시 동일해야 함 ────────────────
MANAGER_ID=admin
MANAGER_PASSWORD=admin
# ⚠️ 세션 토큰 HMAC 서명 키. 카카오 값과 다르면 failover 후 로그인 세션이 전부 무효화된다.
MANAGER_SESSION_SECRET=

# (참고) BE_INTERNAL_URL 은 docker-compose.yml에서 http://backend:8000 으로 고정됨.
# (참고) NEXT_PUBLIC_SUPABASE_URL/ANON_KEY 는 FE 이미지에 빌드타임 baked → 여기서 설정 불필요.
