      "lineRange": [4, 8],
      "summary": "세션 쿠키를 삭제하고 성공 JSON 응답을 반환하는 로그아웃 핸들러.",
      "tags": ["api-handler", "authentication", "logout", "session"],
      "complexity": "simple"
    },
    {
      "id": "file:4K_FE/app/lib/auth.ts",
