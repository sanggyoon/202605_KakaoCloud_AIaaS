# 맥미니 단독 스택 — 단일 .env (cp .env.example .env 후 값 채움). 절대 커밋 금지.
# docker compose --env-file .env -f supabase/docker-compose.yml -f docker-compose.yml ... 로 양쪽 공유.

# ── 도메인 ───────────────────────────────────────────────
FE_DOMAIN=peakly.sanggyoon.com
DATA_DOMAIN=peakly-data.sanggyoon.com
UNDERSTAND_DOMAIN=peakly-understand.sanggyoon.com

# ── FE 빌드타임(브라우저 inline) ─────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://peakly-data.sanggyoon.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=        # = ANON_KEY (아래)

# ── Supabase 코어 (공식 self-host .env 키와 동일) ────────
POSTGRES_PASSWORD=
JWT_SECRET=                            # openssl rand -hex 32 (신규)
ANON_KEY=                              # JWT_SECRET으로 서명한 anon 키(신규)
SERVICE_ROLE_KEY=                      # JWT_SECRET으로 서명한 service_role 키(신규)
DASHBOARD_USERNAME=admin               # studio basic auth(선택)
DASHBOARD_PASSWORD=

# ── 앱(BE) ───────────────────────────────────────────────
DATA_SUPABASE_KEY=                     # = SERVICE_ROLE_KEY
AI_DATABASE_KEY=                       # = SERVICE_ROLE_KEY
AI_SCHEMA=ai                           # ai 스키마 profile (svc는 기본이라 미지정)
TMDB_API_KEY=                          # 선택(메타 갱신 안 쓰면 비움)

# ── 매니저 로그인 (신규 강한 값) ─────────────────────────
MANAGER_ID=admin
MANAGER_PASSWORD=
MANAGER_SESSION_SECRET=                # openssl rand -hex 32 (신규)
