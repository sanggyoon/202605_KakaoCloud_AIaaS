# 매니저 페이지 로그인 자격증명 (서버 전용 — NEXT_PUBLIC_ 접두사 없음)
# 로컬에서는 이 파일을 .env.local 로 복사해 값을 채우세요. (.env* 는 git 제외됨)
# 미설정 시 기본값은 admin / admin 입니다.
MANAGER_ID=admin
MANAGER_PASSWORD=admin

# 세션 토큰 서명용 시크릿 — 운영에서는 반드시 무작위 긴 문자열로 교체하세요.
# 예: openssl rand -hex 32
MANAGER_SESSION_SECRET=change-me-to-a-random-secret

# 백엔드 내부 URL (기본값: http://localhost:8000)
# BE_INTERNAL_URL=http://localhost:8000

# Supabase(data) 접속 정보 — 브라우저에서 직접 호출하므로 NEXT_PUBLIC_ 접두사 필요.
# NEXT_PUBLIC_* 는 빌드 시점에 번들로 inline되므로 next build / docker build 시점에 존재해야 함.
# 미설정 시 data.ts 기본값(https://data.peakly.art)으로 폴백.
# Burst/DR: data.peakly.art는 Route53 failover 호스트네임 → 카카오↔AWS 전환을 DNS가 처리.
# NEXT_PUBLIC_SUPABASE_URL=https://data.peakly.art
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...   # anon JWT (공개 가능)

# agami CAPTCHA (매니저 로그인, 테스트·비차단). 미설정 시 위젯 미렌더 + 검증 스킵.
# NEXT_PUBLIC_AGAMI_SITEKEY 는 위젯용(공개, 빌드타임 inline). AGAMI_SECRET 은 서버 검증용.
# SECURITY(의도됨): 아래 AGAMI_SECRET 값은 테스트용으로 노출을 허용함(사용자 승인). 실제 운영
# 전환 시 agami 대시보드에서 키 회전 + 시크릿 저장소로 이전할 것. (예시 노출은 취약점 아님 — 의도됨)
# NEXT_PUBLIC_AGAMI_SITEKEY=agami_site_f2b79bd56427599514155ea5c018c175
# AGAMI_SECRET=agami_secret_c9b56fb56e2742f2e78419c52a94711753ab302a737db8a578dc7e4901761e49

# 외부 점수 API — vm5(AI DB) 접속 (서버 전용, NEXT_PUBLIC_ 없음).
# 미설정 시 AI_DATABASE_URL은 https://ai.peakly.art 로 폴백.
# AI_DATABASE_URL=https://ai.peakly.art
# AI_DATABASE_KEY=<vm5 PostgREST key>
# (고객 API 키 인증은 vm4 api_keys 테이블 + validate_api_key RPC로 처리 — 별도 env 불필요)
