# 매니저 페이지 로그인 자격증명 (서버 전용 — NEXT_PUBLIC_ 접두사 없음)
# 로컬에서는 이 파일을 .env.local 로 복사해 값을 채우세요. (.env* 는 git 제외됨)
# 미설정 시 기본값은 admin / admin 입니다.
MANAGER_ID=admin
MANAGER_PASSWORD=admin

# 세션 토큰 서명용 시크릿 — 운영에서는 반드시 무작위 긴 문자열로 교체하세요.
# 예: openssl rand -hex 32
MANAGER_SESSION_SECRET=change-me-to-a-random-secret

# 백엔드 내부 URL (기본값: http://localhost:8000)
# BE_INTERNAL_URL=http://localhost:8000
